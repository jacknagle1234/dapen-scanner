{
  "name": "dapen-crawler-runner",
  "version": "1.0.0",
  "description": "HTTP service that receives crawl requests from the DAPEN main app and spawns the Go crawler binary",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node index.js",
    "build:crawler": "GOOS=linux GOARCH=${CRAWLER_ARCH:-amd64} go build -o bin/crawler ./crawler"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1007.0",
    "@axe-core/playwright": "^4.11.1",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "playwright": "^1.58.2"
  }
}
