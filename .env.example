# PostgreSQL connection string (same as main app Neon DB). Passed to the crawler subprocess.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Shared secret; must match the value configured in the main app (Vercel).
# Used to validate Authorization: Bearer <secret>
CRAWLER_SERVICE_SECRET=your-secret-here

# Port for HTTP server (default 8080). Railway/Render/Fly set this automatically.
PORT=8080

# Optional: absolute or relative path to the crawler binary.
# Default: ./bin/crawler
# CRAWLER_BIN_PATH=./bin/crawler

# Optional: S3-compatible storage for screenshots (same bucket as main app images).
# If any are missing, screenshots are skipped and screenshot_key is left null.
# S3_ENDPOINT=https://...
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# IMAGES_BUCKET_NAME=
